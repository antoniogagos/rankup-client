{
	"name": "app-shell",
	"version": "0.0.0",
	"packageManager": "yarn@3.2.3",
	"private": true,
	"@lit-labs/observers": "^1.0.2",
	"scripts": {
		"OLD_test": "tsc && wtr --coverage",
		"OLD_test:watch": "tsc && concurrently -k -r \"tsc -w --preserveWatchOutput\" \"wtr --watch\"",
		"OLD_build": "rimraf dist && tsc && rollup -c rollup.config.js && npm run analyze -- --exclude dist",
		"OLD_start:build": "wds --root-dir dist --app-index index.html --open",
		"OLD_analyze": "cem analyze --litelement",
		"OLD_start-with-rollup-builds": "concurrently --raw \"tsc -b -w --preserveWatchOutput\" \"wds --watch\"",
		"copy-assets": "cpx \"assets/**\" dist/assets & cpx \"index.html\" dist",
		"load-router-pages": "ts-node ./.scripts/load-router-pages.ts",
		"prebuild": "npm run load-router-pages & npm run copy-assets",
		"build": "wireit",
		"prestart": "npm run load-router-pages",
		"start": "wds --watch",
		"validate": "wireit"
	},
	"dependencies": {
		"@lit-labs/context": "^0.1.3",
		"@lit-labs/task": "^1.0.0",
		"lit": "^2.0.2"
	},
	"devDependencies": {
		"@open-wc/testing": "^3.0.0",
		"@web/dev-server": "^0.1.28",
		"@web/dev-server-esbuild": "^0.3.2",
		"concurrently": "^5.3.0",
		"ts-node": "^10.9.1"
	},
	"peerDependencies": {
		"@rankup/common": "^1.0.0",
		"@rankup/samba": "^1.0.0"
	},
	"wireit": {
		"build": {
			"command": "tsc -b"
		},
		"validate": {
			"command": "tsc --noEmit",
			"dependencies": [
				"build"
			]
		}
	}
}
