{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"composite": true,
		"baseUrl": "./",
		"rootDir": "./",
		"outDir": "./dist"
	},
	"ts-node": {
		"compilerOptions": {
			"target": "ESNext",
			"module": "CommonJS",
			"resolveJsonModule": true,
			"esModuleInterop": true,
			"moduleResolution": "node",
			"allowSyntheticDefaultImports": true
		}
	},
	"references": [{ "path": "../samba" }, { "path": "../common" }],
	"include": ["**/*.ts", "**/*.js", "**/*.json"]
}
