{
	"routes": [
		{
			"path": "/",
			"localize": false,
			"publicPage": true,
			"componentName": "pp-welcome-page",
			"componentPath": "./pages/welcome/pp-welcome-page.ts"
		},
		{
			"path": "/404",
			"localize": false,
			"publicPage": true,
			"componentName": "pp-404-page",
			"componentPath": "./pages/404/pp-404-page.ts"
		},
		{
			"path": "*",
			"localize": false,
			"publicPage": true,
			"redirect": "/404"
		}
	]
}
