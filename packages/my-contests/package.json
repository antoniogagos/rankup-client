{
	"name": "@rankup/my-contests",
	"version": "1.0.0",
	"packageManager": "yarn@3.2.3",
	"private": true,
	"scripts": {
		"copy-assets": "cpx \"assets/**\" dist/assets & cpx \"index.html\" dist",
		"prestart": "npm run copy-assets",
		"start": "concurrently --raw \"tsc -b -w --preserveWatchOutput\" \"wds --watch\"",
		"validate": "tsc --noEmit"
	},
	"devDependencies": {
		"@open-wc/testing": "^3.0.0",
		"@web/dev-server": "^0.1.28",
		"@web/dev-server-esbuild": "^0.3.2",
		"concurrently": "^5.3.0"
	},
	"peerDependencies": {
		"@lit-labs/context": "^0.1.3",
		"@lit-labs/task": "^1.0.0",
		"@rankup/common": "^1.0.0",
		"@rankup/samba": "^1.0.0",
		"lit": "^2.0.2"
	}
}
