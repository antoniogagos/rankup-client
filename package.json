{
	"name": "rk-app",
	"version": "0.0.0",
	"packageManager": "yarn@3.0.1",
	"private": true,
	"customElements": "custom-elements.json",
	"workspaces": [
		"packages/*"
	],
	"engines": {
		"node": "16.17.0"
	},
	"scripts": {
		"OLD_lint": "eslint --ext .js,.ts,.html . --ignore-path .gitignore && prettier \"**/*.ts\" --check --ignore-path .gitignore",
		"OLD_format": "eslint --ext .ts,.html . --fix --ignore-path .gitignore && prettier \"**/*.ts\" --write --ignore-path .gitignore",
		"OLD_test": "tsc && wtr --coverage",
		"OLD_test:watch": "tsc && concurrently -k -r \"tsc --watch --preserveWatchOutput\" \"wtr --watch\"",
		"OLD_build": "rimraf dist && tsc && rollup -c rollup.config.js && npm run analyze -- --exclude dist",
		"OLD_start:build": "web-dev-server --root-dir dist --app-index index.html --open",
		"OLD_analyze": "cem analyze --litelement",
		"lint": "eslint ./packages --max-warnings=0",
		"postinstall": "husky install",
		"start": "npm run start --workspace=app",
		"validate": "npm run --workspace app validate && npm run lint"
	},
	"devDependencies": {
		"@babel/preset-env": "^7.16.4",
		"@custom-elements-manifest/analyzer": "^0.4.17",
		"@open-wc/building-rollup": "^2.0.2",
		"@open-wc/eslint-config": "^8.0.0",
		"@rollup/plugin-alias": "^3.1.9",
		"@rollup/plugin-babel": "^5.3.0",
		"@rollup/plugin-node-resolve": "^13.0.6",
		"@typescript-eslint/eslint-plugin": "^5.33.0",
		"@typescript-eslint/parser": "^5.33.0",
		"@web/rollup-plugin-html": "^1.10.1",
		"@web/rollup-plugin-import-meta-assets": "^1.0.7",
		"@web/test-runner": "next",
		"babel-plugin-template-html-minifier": "^4.1.0",
		"cpx": "^1.5.0",
		"deepmerge": "^4.2.2",
		"eslint": "^8.21.0",
		"eslint-config-prettier": "^8.5.0",
		"eslint-plugin-custom-elements": "^0.0.6",
		"eslint-plugin-import": "^2.26.0",
		"eslint-plugin-jsx-a11y": "^6.6.1",
		"eslint-plugin-lit-a11y": "^2.0.0",
		"eslint-plugin-prettier": "^4.2.1",
		"eslint-plugin-promise": "^6.0.0",
		"eslint-plugin-react": "^7.30.1",
		"eslint-plugin-react-hooks": "^4.6.0",
		"eslint-plugin-simple-import-sort": "^7.0.0",
		"husky": "^8.0.1",
		"jest": "^28.0.0",
		"lint-staged": "^10.5.4",
		"prettier": "^2.7.1",
		"rimraf": "^3.0.2",
		"rollup": "^2.60.0",
		"rollup-plugin-import-assert": "^2.1.0",
		"rollup-plugin-postcss": "^4.0.2",
		"rollup-plugin-terser": "^7.0.2",
		"rollup-plugin-workbox": "^6.2.0",
		"ts-jest": "^28.0.8",
		"tslib": "^2.3.1",
		"typescript": "^4.5.2"
	},
	"prettier": {
		"printWidth": 100,
		"singleQuote": true,
		"arrowParens": "avoid",
		"useTabs": true,
		"semi": true,
		"bracketSpacing": true,
		"bracketSameLine": true,
		"trailingComma": "all"
	},
	"eslintConfig": {
		"parser": "@typescript-eslint/parser",
		"env": {
			"es6": true,
			"browser": true,
			"node": false
		},
		"parserOptions": {
			"ecmaVersion": "latest"
		},
		"plugins": [
			"@typescript-eslint",
			"rankup",
			"simple-import-sort",
			"import",
			"promise",
			"prettier"
		],
		"extends": [
			"@open-wc",
			"plugin:custom-elements/recommended",
			"plugin:@typescript-eslint/eslint-recommended",
			"plugin:@typescript-eslint/recommended",
			"plugin:import/typescript",
			"plugin:promise/recommended",
			"plugin:promise/recommended",
			"plugin:rankup/recommended",
			"prettier"
		],
		"rules": {
			"@typescript-eslint/ban-ts-comment": "off",
			"@typescript-eslint/no-empty-interface": "off",
			"@typescript-eslint/no-explicit-any": "off",
			"@typescript-eslint/no-non-null-assertion": "off",
			"@typescript-eslint/no-shadow": [
				"error"
			],
			"@typescript-eslint/no-use-before-define": [
				"error",
				{
					"functions": false,
					"classes": false,
					"variables": true,
					"ignoreTypeReferences": true
				}
			],
			"class-methods-use-this": "off",
			"consistent-return": "off",
			"import/extensions": [
				"error",
				"always",
				{
					"ignorePackages": true
				}
			],
			"import/no-absolute-path": "off",
			"import/no-unresolved": "off",
			"simple-import-sort/exports": "error",
			"simple-import-sort/imports": "error",
			"import/newline-after-import": "off",
			"no-await-in-loop": "off",
			"no-console": "off",
			"no-dupe-class-members": "off",
			"no-shadow": "off",
			"no-undef": "off",
			"no-unused-vars": 0,
			"no-use-before-define": "off",
			"no-useless-escape": "off",
			"prefer-destructuring": "off",
			"prefer-template": "off",
			"custom-elements/define-tag-after-class-definition": "off",
			"custom-elements/file-name-matches-element": "error",
			"custom-elements/expose-class-on-global": "off",
			"custom-elements/no-constructor": "off",
			"promise/catch-or-return": "off",
			"promise/always-return": "off"
		}
	}
}
